<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="arm_ros2_control" params="name use_mock_hardware:=false">
    <ros2_control name="${name}" type="system">
      <hardware>
        <xacro:if value="${use_mock_hardware}">
          <plugin>mock_components/GenericSystem</plugin>
        </xacro:if>
        <xacro:unless value="${use_mock_hardware}">
          <plugin>arm_hardware_interface/ArmHardwareInterface</plugin>
        </xacro:unless>
        <!-- Pass the URDF path to the hardware interface for Pinocchio -->
        <param name="robot_description_path">$(find my_robot_description)/urdf/my_robot.urdf.xacro</param>
      </hardware>

      <!-- J1-J4 使用 can1 -->
      <joint name="joint1">
        <command_interface name="position"/>
        <command_interface name="velocity"/>
        <command_interface name="effort"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
        <param name="can_id">1</param>
        <param name="motor_model">J8009</param>
        <param name="can_bus">can0</param>
        <param name="kp">120.0</param>
        <param name="kd">4.0</param>
      </joint>

      <joint name="joint2">
        <command_interface name="position"/>
        <command_interface name="velocity"/>
        <command_interface name="effort"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
        <param name="can_id">2</param>
        <param name="motor_model">J8009</param>
        <param name="can_bus">can0</param>
        <param name="kp">120.0</param>
        <param name="kd">4.0</param>
      </joint>

      <joint name="joint3">
        <command_interface name="position"/>
        <command_interface name="velocity"/>
        <command_interface name="effort"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
        <param name="can_id">3</param>
        <param name="motor_model">J8009</param>
        <param name="can_bus">can0</param>
        <param name="kp">120.0</param>
        <param name="kd">4.0</param>
      </joint>

      <joint name="joint4">
        <command_interface name="position"/>
        <command_interface name="velocity"/>
        <command_interface name="effort"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
        <param name="can_id">4</param>
        <param name="motor_model">J4340</param>
        <param name="can_bus">can0</param>
        <param name="kp">60.0</param>
        <param name="kd">3.0</param>
      </joint>

      <!-- J5-J7 使用 can0 -->
      <joint name="joint5">
        <command_interface name="position"/>
        <command_interface name="velocity"/>
        <command_interface name="effort"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
        <param name="can_id">5</param>
        <param name="motor_model">J4340</param>
        <param name="can_bus">can1</param>
        <param name="kp">60.0</param>
        <param name="kd">3.0</param>
      </joint>

      <joint name="joint6">
        <command_interface name="position"/>
        <command_interface name="velocity"/>
        <command_interface name="effort"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
        <param name="can_id">6</param>
        <param name="motor_model">J4310</param>
        <param name="can_bus">can1</param>
        <param name="kp">60.0</param>
        <param name="kd">1.0</param>
      </joint>

      <joint name="joint7">
        <command_interface name="position"/>
        <command_interface name="velocity"/>
        <command_interface name="effort"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
        <param name="can_id">7</param>
        <param name="motor_model">J4310</param>
        <param name="can_bus">can1</param>
        <param name="kp">60.0</param>
        <param name="kd">1.0</param>
      </joint>

    </ros2_control>
  </xacro:macro>

</robot>
