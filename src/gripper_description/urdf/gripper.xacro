<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ==================== gripper_base_link ==================== -->
  <link name="gripper_base_link">
    <inertial>
      <origin xyz="0.024119 -0.00025348 1.4037E-05" rpy="0 0 0"/>
      <mass value="0.10268"/>
      <inertia ixx="4.2026E-05" ixy="-4.1834E-08" ixz="-5.3192E-10"
               iyy="3.0131E-05" iyz="2.7197E-08" izz="3.0109E-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://gripper_description/meshes/gripper_base_link.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://gripper_description/meshes/gripper_base_link.STL"/>
      </geometry>
    </collision>
  </link>

  <!-- ==================== grippeer_Link (gripper body) ==================== -->
  <link name="grippeer_Link">
    <inertial>
      <origin xyz="0.040428 -0.00017354 1.2493E-05" rpy="0 0 0"/>
      <mass value="0.093865"/>
      <inertia ixx="0.00022061" ixy="1.0893E-19" ixz="3.8261E-21"
               iyy="2.9769E-05" iyz="-2.4504E-16" izz="0.00019995"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://gripper_description/meshes/grippeer_Link.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://gripper_description/meshes/grippeer_Link.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_gripper" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="gripper_base_link"/>
    <child link="grippeer_Link"/>
  </joint>

  <!-- ==================== right_finger_Link ==================== -->
  <link name="right_finger_Link">
    <inertial>
      <origin xyz="0.032482 0.0068743 0.00084038" rpy="0 0 0"/>
      <mass value="0.095586"/>
      <inertia ixx="2.0674E-05" ixy="-5.6199E-06" ixz="-1.1351E-08"
               iyy="9.0681E-05" iyz="4.7589E-08" izz="0.0001011"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://gripper_description/meshes/right_finger_Link.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://gripper_description/meshes/right_finger_Link.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_right_finger" type="prismatic">
    <origin xyz="0.071 0.059926 1.2493E-05" rpy="0 0 0"/>
    <parent link="grippeer_Link"/>
    <child link="right_finger_Link"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.04" upper="0" effort="2" velocity="2"/>
  </joint>

  <!-- ==================== left_finger_Link ==================== -->
  <link name="left_finger_Link">
    <inertial>
      <origin xyz="0.032717 -0.0068743 -0.00084038" rpy="0 0 0"/>
      <mass value="0.095586"/>
      <inertia ixx="2.0674E-05" ixy="5.6199E-06" ixz="1.1351E-08"
               iyy="9.0681E-05" iyz="4.7589E-08" izz="0.0001011"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://gripper_description/meshes/left_finger_Link.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://gripper_description/meshes/left_finger_Link.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_left_finger" type="prismatic">
    <origin xyz="0.071 -0.060274 1.2493E-05" rpy="0 0 0"/>
    <parent link="grippeer_Link"/>
    <child link="left_finger_Link"/>
    <axis xyz="0 1 0"/>
    <mimic joint="joint_right_finger" multiplier="-1.0" offset="0"/>
    <limit lower="0" upper="0.04" effort="2" velocity="2"/>
  </joint>


  <!-- ==================== link_ee (End Effector) ==================== -->
  <link name="link_ee"/>

  <joint name="joint_ee" type="fixed">
    <origin xyz="0.13 0 0" rpy="0 0 0"/>
    <parent link="gripper_base_link"/>
    <child link="link_ee"/>
  </joint>

</robot>
